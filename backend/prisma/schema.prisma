generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum LoadType {
  BODYWEIGHT
  ASSISTED_BODYWEIGHT
  EXTERNAL
  FIXED_WEIGHT
  PLATE_TOTAL
  STACK
  CABLE_STACK
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
}

enum TrackingMode {
  ABSOLUTE_WEIGHT
  PLATES_PER_SIDE
  BODYWEIGHT_ONLY
  BODYWEIGHT_PLUS_LOAD
  BAND_LEVEL
  PER_SIDE_LOAD
  CARDIO
}

enum WorkoutSetType {
  NORMAL
  WARMUP
  AMRAP
  DROP
  CLUSTER
  SUPERSET
  CARDIO
}

enum ProgramStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum WorkoutEntryType {
  PROGRAM
  TEMPLATE
  QUICK
}

enum WorkoutStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum ActivityType {
  WORKOUT_COMPLETED
  PR_HIT
  LEVEL_UP
  ACHIEVEMENT_UNLOCKED
  STREAK_EXTENDED
  CHALLENGE_JOINED
  PROGRAM_WEEK_COMPLETED
}

enum ChallengeMetric {
  XP
  WORKOUTS
  PROGRAM_WEEKS
  PRS
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  displayName          String
  xpTotal              Int                  @default(0)
  level                Int                  @default(1)
  avatarConfig         Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  authIdentities       AuthIdentity[]
  sessions             Session[]
  exercises            Exercise[]
  exerciseEquivalencies ExerciseEquivalency[]
  programs             Program[]
  templates            WorkoutTemplate[]
  workoutSessions      WorkoutSession[]
  progressionSnapshots ProgressionSnapshot[]
  xpLedgerEntries      XpLedger[]
  userAchievements     UserAchievement[]
  avatarInventory      UserAvatarItem[]
  activityEvents       ActivityEvent[]
  following            Follow[]             @relation("following")
  followers            Follow[]             @relation("followers")
  challengeEntries     ChallengeParticipant[]
  skippedProgramWorkouts ProgramWorkoutSkip[]
}

model AuthIdentity {
  id              String       @id @default(cuid())
  userId          String
  provider        AuthProvider
  providerSubject String
  passwordHash    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exercise {
  id                  String                  @id @default(cuid())
  userId              String?
  slug                String
  name                String
  exerciseCategory    ExerciseCategory        @default(STRENGTH)
  equipmentType       String
  machineType         String?
  attachment          String?
  loadType            LoadType
  unitMode            String                  @default("kg")
  primaryMuscles      String[]
  secondaryMuscles    String[]
  isSystem            Boolean                 @default(false)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  user                User?                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceEquivalencies ExerciseEquivalency[]   @relation("equivalencySource")
  targetEquivalencies ExerciseEquivalency[]   @relation("equivalencyTarget")
  programExercises    ProgramWorkoutExercise[]
  templateExercises   TemplateExercise[]

  @@unique([userId, slug])
}

model ExerciseEquivalency {
  id               String   @id @default(cuid())
  userId           String?
  sourceExerciseId String
  targetExerciseId String
  createdAt        DateTime @default(now())
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceExercise   Exercise @relation("equivalencySource", fields: [sourceExerciseId], references: [id], onDelete: Cascade)
  targetExercise   Exercise @relation("equivalencyTarget", fields: [targetExerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceExerciseId, targetExerciseId])
}

model Program {
  id                   String               @id @default(cuid())
  userId               String
  isSystem             Boolean              @default(false)
  name                 String
  goal                 String
  description          String?
  status               ProgramStatus        @default(PAUSED)
  currentWeek          Int                  @default(1)
  adherenceStreak      Int                  @default(0)
  graceHours           Int                  @default(48)
  startedAt            DateTime?
  pausedAt             DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeks                ProgramWeek[]
  sessions             WorkoutSession[]
  progressionSnapshots ProgressionSnapshot[]
  skippedWorkouts      ProgramWorkoutSkip[]
}

model ProgramWeek {
  id         String           @id @default(cuid())
  programId  String
  weekNumber Int
  label      String
  isDeload   Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  program    Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  workouts   ProgramWorkout[]

  @@unique([programId, weekNumber])
}

model ProgramWorkout {
  id               String                  @id @default(cuid())
  programWeekId    String
  dayLabel         String
  title            String
  orderIndex       Int
  estimatedMinutes Int                     @default(60)
  xpReward         Int                     @default(100)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  programWeek      ProgramWeek             @relation(fields: [programWeekId], references: [id], onDelete: Cascade)
  exercises        ProgramWorkoutExercise[]
  workoutSessions  WorkoutSession[]
  skips            ProgramWorkoutSkip[]
}

model ProgramWorkoutExercise {
  id                  String         @id @default(cuid())
  programWorkoutId    String
  exerciseId          String
  orderIndex          Int
  sets                Int
  repMin              Int
  repMax              Int
  restSeconds         Int            @default(120)
  startWeight         Float?
  increment           Float          @default(2.5)
  deloadFactor        Float          @default(0.9)
  targetRpe           Float?
  loadTypeOverride    LoadType?
  trackingMode        TrackingMode?
  defaultTrackingData Json?
  machineOverride     String?
  attachmentOverride  String?
  unilateral          Boolean        @default(false)
  notes               String?
  programWorkout      ProgramWorkout @relation(fields: [programWorkoutId], references: [id], onDelete: Cascade)
  exercise            Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
}

model WorkoutTemplate {
  id          String             @id @default(cuid())
  userId      String
  isSystem    Boolean            @default(false)
  name        String
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises   TemplateExercise[]
}

model TemplateExercise {
  id                  String          @id @default(cuid())
  templateId          String
  exerciseId          String
  orderIndex          Int
  sets                Int
  repMin              Int
  repMax              Int
  restSeconds         Int             @default(120)
  startWeight         Float?
  loadTypeOverride    LoadType?
  trackingMode        TrackingMode?
  defaultTrackingData Json?
  machineOverride     String?
  attachmentOverride  String?
  unilateral          Boolean         @default(false)
  notes               String?
  template            WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercise            Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
}

model WorkoutSession {
  id                       String           @id @default(cuid())
  userId                   String
  programId                String?
  programWorkoutId         String?
  templateId               String?
  title                    String
  entryType                WorkoutEntryType
  status                   WorkoutStatus    @default(IN_PROGRESS)
  startedAt                DateTime         @default(now())
  pausedAt                 DateTime?
  accumulatedPauseSeconds  Int              @default(0)
  totalDurationSeconds     Int?
  completedAt              DateTime?
  notes                    String?
  totalXp                  Int              @default(0)
  wasPlanned               Boolean          @default(false)
  qualifiesForProgression  Boolean          @default(true)
  savedDraft               Json?
  originDraft              Json?
  user                     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  program                  Program?         @relation(fields: [programId], references: [id], onDelete: SetNull)
  programWorkout           ProgramWorkout?  @relation(fields: [programWorkoutId], references: [id], onDelete: SetNull)
  exercises                WorkoutExercise[]
}

model ProgramWorkoutSkip {
  id              String         @id @default(cuid())
  userId          String
  programId       String
  programWorkoutId String
  weekNumber      Int
  skippedAt       DateTime       @default(now())
  reason          String?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  program         Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  programWorkout  ProgramWorkout @relation(fields: [programWorkoutId], references: [id], onDelete: Cascade)

  @@unique([userId, programWorkoutId, weekNumber])
}

model WorkoutExercise {
  id                     String          @id @default(cuid())
  sessionId              String
  exerciseId             String?
  exerciseName           String
  exerciseCategory       ExerciseCategory @default(STRENGTH)
  equipmentType          String
  machineType            String?
  attachment             String?
  loadType               LoadType
  trackingMode           TrackingMode?
  defaultTrackingData    Json?
  unitMode               String          @default("kg")
  unilateral             Boolean         @default(false)
  orderIndex             Int
  notes                  String?
  prescribedSetCount     Int?
  repMin                 Int?
  repMax                 Int?
  suggestedWeight        Float?
  sourceProgramExerciseId String?
  substitutedFromExerciseId String?
  substitutedFromExerciseName String?
  substitutionMode       String?
  countsForProgression   Boolean         @default(true)
  supersetGroupId        String?
  supersetPosition       Int?
  session                WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sets                   WorkoutSet[]
}

model WorkoutSet {
  id                String          @id @default(cuid())
  workoutExerciseId String
  setNumber         Int
  weight            Float?
  reps              Int
  rpe               Float?
  setType           WorkoutSetType  @default(NORMAL)
  trackingData      Json?
  completedAt       DateTime        @default(now())
  isWorkingSet      Boolean         @default(true)
  isPersonalRecord  Boolean         @default(false)
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
}

model ProgressionSnapshot {
  id                     String   @id @default(cuid())
  userId                 String
  programId              String
  programWorkoutExerciseId String
  recommendedWeight      Float?
  state                  String
  reason                 String
  createdAt              DateTime @default(now())
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program                Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model XpLedger {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id                String            @id @default(cuid())
  key               String            @unique
  title             String
  description       String
  xpReward          Int               @default(0)
  requirementType   String
  requirementTarget Int               @default(1)
  userAchievements  UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model AvatarItem {
  id          String           @id @default(cuid())
  key         String           @unique
  title       String
  slot        String
  unlockLevel Int              @default(1)
  costXp      Int?
  inventory   UserAvatarItem[]
}

model UserAvatarItem {
  id           String     @id @default(cuid())
  userId       String
  avatarItemId String
  unlockedAt   DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarItem   AvatarItem @relation(fields: [avatarItemId], references: [id], onDelete: Cascade)

  @@unique([userId, avatarItemId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Challenge {
  id           String                @id @default(cuid())
  key          String                @unique
  title        String
  description  String
  metric       ChallengeMetric
  periodStart  DateTime
  periodEnd    DateTime
  target       Int?
  isActive     Boolean               @default(true)
  participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id          String    @id @default(cuid())
  challengeId String
  userId      String
  score       Int       @default(0)
  joinedAt    DateTime  @default(now())
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

model ActivityEvent {
  id        String       @id @default(cuid())
  userId    String
  type      ActivityType
  title     String
  body      String?
  payload   Json?
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}
