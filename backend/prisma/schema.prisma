generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum LoadType {
  BODYWEIGHT
  ASSISTED_BODYWEIGHT
  EXTERNAL
  FIXED_WEIGHT
  PLATE_TOTAL
  STACK
  CABLE_STACK
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
}

enum TrackingMode {
  ABSOLUTE_WEIGHT
  PLATES_PER_SIDE
  PLATES_TOTAL
  BODYWEIGHT_ONLY
  BODYWEIGHT_PLUS_LOAD
  BAND_LEVEL
  PER_SIDE_LOAD
  CARDIO
}

enum WorkoutSetType {
  NORMAL
  WARMUP
  AMRAP
  DROP
  CLUSTER
  SUPERSET
  CARDIO
}

enum ProgramStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum WorkoutEntryType {
  PROGRAM
  TEMPLATE
  QUICK
}

enum WorkoutStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum ActivityType {
  WORKOUT_COMPLETED
  PR_HIT
  LEVEL_UP
  ACHIEVEMENT_UNLOCKED
  CHALLENGE_TIER_UNLOCKED
  STREAK_EXTENDED
  CHALLENGE_JOINED
  PROGRAM_WEEK_COMPLETED
}

enum ChallengeCategory {
  CONSISTENCY
  STRENGTH
  PROGRESSION
  PROGRAMS
  SOCIAL
}

enum ChallengeRank {
  ROOKIE
  REGULAR
  DEDICATED
  SERIOUS
  SAVAGE
  TITAN
  GOD
}

enum UserGender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum ChallengeMetric {
  XP
  WORKOUTS
  PROGRAM_WEEKS
  PRS
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  displayName          String
  preferredUnit        String               @default("kg")
  gender               UserGender           @default(PREFER_NOT_TO_SAY)
  xpTotal              Int                  @default(0)
  level                Int                  @default(1)
  challengeMigrationVersion Int            @default(0)
  selectedTitleKey     String?
  selectedTitleLabel   String?
  selectedBadgeKey     String?
  selectedBadgeLabel   String?
  selectedBadgeIconKey String?
  avatarConfig         Json?
  settings             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  authIdentities       AuthIdentity[]
  sessions             Session[]
  exercises            Exercise[]
  exerciseEquivalencies ExerciseEquivalency[]
  programs             Program[]
  templates            WorkoutTemplate[]
  workoutSessions      WorkoutSession[]
  progressionSnapshots ProgressionSnapshot[]
  xpLedgerEntries      XpLedger[]
  userAchievements     UserAchievement[]
  challengeProgresses  UserChallengeProgress[]
  challengeTierUnlocks UserChallengeTierUnlock[]
  avatarInventory      UserAvatarItem[]
  activityEvents       ActivityEvent[]
  following            Follow[]             @relation("following")
  followers            Follow[]             @relation("followers")
  challengeEntries     ChallengeParticipant[]
  reactions            Reaction[]           @relation("reactions")
  notifications        Notification[]
  sentInvites          WorkoutInvite[]      @relation("sentInvites")
  receivedInvites      WorkoutInvite[]      @relation("receivedInvites")
  skippedProgramWorkouts ProgramWorkoutSkip[]
  bodyMetricEntries    BodyMetricEntry[]
  exercisePreferences  UserExercisePreference[]
  progressionTracks    ProgressionTrack[]
  cardioSessions       CardioSession[]
  supplements          Supplement[]
  supplementStacks     SupplementStack[]
  supplementCycles     SupplementCycle[]
  supplementIntakes    SupplementIntake[]
  pushSubscriptions    PushSubscription[]
}

enum CardioActivity {
  TREADMILL
  BIKE
  ROWER
  STAIR
  ELLIPTICAL
  OUTDOOR_RUN
  OUTDOOR_WALK
  OUTDOOR_CYCLE
  OTHER
}

model CardioSession {
  id                String         @id @default(cuid())
  userId            String
  activity          CardioActivity
  performedAt       DateTime
  durationSeconds   Int
  distanceMeters    Float? // canonical meters (convert km/mi at edges)
  avgSpeedKmh       Float?
  inclinePct        Float?
  resistanceLevel   Float?
  avgWatts          Float?
  avgHr             Int?
  maxHr             Int?
  rpe               Float? // 0-10 device-free effort proxy
  caloriesEstimated Float? // from the engine
  caloriesManual    Float? // machine override
  bodyweightKgAt    Float? // snapshot used for the estimate (recompute integrity)
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, performedAt(sort: Desc)])
}

model AuthIdentity {
  id              String       @id @default(cuid())
  userId          String
  provider        AuthProvider
  providerSubject String
  passwordHash    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exercise {
  id                  String                  @id @default(cuid())
  userId              String?
  slug                String
  name                String
  exerciseCategory    ExerciseCategory        @default(STRENGTH)
  equipmentType       String
  machineType         String?
  attachment          String?
  loadType            LoadType
  unitMode            String                  @default("kg")
  primaryMuscles      String[]
  secondaryMuscles    String[]
  isSystem            Boolean                 @default(false)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  user                User?                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceEquivalencies ExerciseEquivalency[]   @relation("equivalencySource")
  targetEquivalencies ExerciseEquivalency[]   @relation("equivalencyTarget")
  programExercises    ProgramWorkoutExercise[]
  templateExercises   TemplateExercise[]
  userPreferences     UserExercisePreference[]

  @@unique([userId, slug])
}

model UserExercisePreference {
  id           String        @id @default(cuid())
  userId       String
  exerciseId   String
  unilateral   Boolean?
  trackingMode TrackingMode?
  barWeight    Float?
  restSeconds  Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise     Exercise      @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
}

model ExerciseEquivalency {
  id               String   @id @default(cuid())
  userId           String?
  sourceExerciseId String
  targetExerciseId String
  createdAt        DateTime @default(now())
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceExercise   Exercise @relation("equivalencySource", fields: [sourceExerciseId], references: [id], onDelete: Cascade)
  targetExercise   Exercise @relation("equivalencyTarget", fields: [targetExerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceExerciseId, targetExerciseId])
}

model Program {
  id                   String               @id @default(cuid())
  userId               String
  isSystem             Boolean              @default(false)
  name                 String
  goal                 String
  description          String?
  status               ProgramStatus        @default(PAUSED)
  currentWeek          Int                  @default(1)
  adherenceStreak      Int                  @default(0)
  graceHours           Int                  @default(48)
  allowCopy            Boolean              @default(false)
  startedAt            DateTime?
  pausedAt             DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeks                ProgramWeek[]
  sessions             WorkoutSession[]
  progressionSnapshots ProgressionSnapshot[]
  progressionTracks    ProgressionTrack[]
  skippedWorkouts      ProgramWorkoutSkip[]

  @@index([userId, status])
}

model ProgramWeek {
  id         String           @id @default(cuid())
  programId  String
  weekNumber Int
  label      String
  isDeload   Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  program    Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  workouts   ProgramWorkout[]

  @@unique([programId, weekNumber])
}

model ProgramWorkout {
  id               String                  @id @default(cuid())
  programWeekId    String
  dayLabel         String
  title            String
  orderIndex       Int
  estimatedMinutes Int                     @default(60)
  xpReward         Int                     @default(100)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  programWeek      ProgramWeek             @relation(fields: [programWeekId], references: [id], onDelete: Cascade)
  exercises        ProgramWorkoutExercise[]
  workoutSessions  WorkoutSession[]
  skips            ProgramWorkoutSkip[]
}

model ProgramWorkoutExercise {
  id                  String         @id @default(cuid())
  programWorkoutId    String
  exerciseId          String
  orderIndex          Int
  sets                Int
  repMin              Int
  repMax              Int
  restSeconds         Int            @default(120)
  startWeight         Float?
  increment           Float          @default(2.5)
  deloadFactor        Float          @default(0.9)
  targetRpe           Float?
  loadTypeOverride    LoadType?
  trackingMode        TrackingMode?
  defaultTrackingData Json?
  machineOverride     String?
  attachmentOverride  String?
  unilateral          Boolean        @default(false)
  notes               String?
  programWorkout      ProgramWorkout @relation(fields: [programWorkoutId], references: [id], onDelete: Cascade)
  exercise            Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([programWorkoutId])
  @@index([exerciseId])
}

model WorkoutTemplate {
  id          String             @id @default(cuid())
  userId      String
  isSystem    Boolean            @default(false)
  name        String
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises   TemplateExercise[]
}

model TemplateExercise {
  id                  String          @id @default(cuid())
  templateId          String
  exerciseId          String
  orderIndex          Int
  sets                Int
  repMin              Int
  repMax              Int
  restSeconds         Int             @default(120)
  startWeight         Float?
  loadTypeOverride    LoadType?
  trackingMode        TrackingMode?
  defaultTrackingData Json?
  machineOverride     String?
  attachmentOverride  String?
  unilateral          Boolean         @default(false)
  notes               String?
  template            WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercise            Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
}

model WorkoutSession {
  id                       String           @id @default(cuid())
  userId                   String
  programId                String?
  programWorkoutId         String?
  templateId               String?
  title                    String
  entryType                WorkoutEntryType
  status                   WorkoutStatus    @default(IN_PROGRESS)
  startedAt                DateTime         @default(now())
  pausedAt                 DateTime?
  accumulatedPauseSeconds  Int              @default(0)
  totalDurationSeconds     Int?
  completedAt              DateTime?
  notes                    String?
  totalXp                  Int              @default(0)
  wasPlanned               Boolean          @default(false)
  qualifiesForProgression  Boolean          @default(true)
  inviteId                 String?
  readiness                Json?
  savedDraft               Json?
  originDraft              Json?
  user                     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  program                  Program?         @relation(fields: [programId], references: [id], onDelete: SetNull)
  programWorkout           ProgramWorkout?  @relation(fields: [programWorkoutId], references: [id], onDelete: SetNull)
  exercises                WorkoutExercise[]

  @@index([userId, status, completedAt(sort: Desc)])
  @@index([userId, status, startedAt(sort: Desc)])
  @@index([userId, programId, status])
  @@index([userId, programWorkoutId, status])
}

model ProgramWorkoutSkip {
  id              String         @id @default(cuid())
  userId          String
  programId       String
  programWorkoutId String
  weekNumber      Int
  skippedAt       DateTime       @default(now())
  reason          String?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  program         Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  programWorkout  ProgramWorkout @relation(fields: [programWorkoutId], references: [id], onDelete: Cascade)

  @@unique([userId, programWorkoutId, weekNumber])
}

model WorkoutExercise {
  id                     String          @id @default(cuid())
  sessionId              String
  exerciseId             String?
  exerciseName           String
  exerciseCategory       ExerciseCategory @default(STRENGTH)
  equipmentType          String
  machineType            String?
  attachment             String?
  loadType               LoadType
  trackingMode           TrackingMode?
  defaultTrackingData    Json?
  unitMode               String          @default("kg")
  unilateral             Boolean         @default(false)
  orderIndex             Int
  notes                  String?
  prescribedSetCount     Int?
  repMin                 Int?
  repMax                 Int?
  suggestedWeight        Float?
  sourceProgramExerciseId String?
  substitutedFromExerciseId String?
  substitutedFromExerciseName String?
  substitutionMode       String?
  countsForProgression   Boolean         @default(true)
  supersetGroupId        String?
  supersetPosition       Int?
  session                WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sets                   WorkoutSet[]

  @@index([sessionId])
  @@index([sourceProgramExerciseId, sessionId])
  @@index([exerciseId, sessionId])
}

model WorkoutSet {
  id                String          @id @default(cuid())
  workoutExerciseId String
  setNumber         Int
  weight            Float?
  reps              Int
  rpe               Float?
  setType           WorkoutSetType  @default(NORMAL)
  trackingData      Json?
  completedAt       DateTime        @default(now())
  isWorkingSet      Boolean         @default(true)
  isPersonalRecord  Boolean         @default(false)
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@index([workoutExerciseId])
}

enum ProgressionTrackStatus {
  FORMATIVE
  ACTIVE
  DELOADED
}

model ProgressionTrack {
  id                       String                 @id @default(cuid())
  userId                   String
  programId                String
  programWorkoutExerciseId String
  status                   ProgressionTrackStatus @default(FORMATIVE)
  workingWeight            Float?
  baselineWeight           Float?
  stallWeight              Float?
  suggestedWeight          Float?
  suggestionReason         String?
  successStreak            Int                    @default(0)
  failStreak               Int                    @default(0)
  lastOutcomes             Json?
  lastEvaluatedSessionId   String?
  lastEvaluatedAt          DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  user                     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  program                  Program                @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programWorkoutExerciseId])
  @@index([userId, programId])
}

model ProgressionSnapshot {
  id                     String   @id @default(cuid())
  userId                 String
  programId              String
  programWorkoutExerciseId String
  recommendedWeight      Float?
  state                  String
  reason                 String
  createdAt              DateTime @default(now())
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program                Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([userId, programId])
}

model XpLedger {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id                String            @id @default(cuid())
  key               String            @unique
  title             String
  description       String
  xpReward          Int               @default(0)
  requirementType   String
  requirementTarget Int               @default(1)
  userAchievements  UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model ChallengeFamily {
  id          String                @id @default(cuid())
  key         String                @unique
  category    ChallengeCategory
  metricKey   String
  iconKey     String
  title       String
  description String
  unitSingular String
  unitPlural  String
  sortOrder   Int                   @default(0)
  isActive    Boolean               @default(true)
  tiers       ChallengeTier[]
  progresses  UserChallengeProgress[]
}

model ChallengeTier {
  id               String                  @id @default(cuid())
  familyId         String
  rank             ChallengeRank
  threshold        Int
  femaleThreshold  Int?
  xpReward         Int                     @default(0)
  titleRewardKey   String?
  titleRewardLabel String?
  badgeRewardKey   String?
  badgeRewardLabel String?
  badgeRewardIconKey String?
  family           ChallengeFamily         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  unlocks          UserChallengeTierUnlock[]

  @@unique([familyId, rank])
  @@unique([familyId, threshold])
}

model UserChallengeProgress {
  id        String         @id @default(cuid())
  userId    String
  familyId  String
  progress  Int            @default(0)
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  family    ChallengeFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([userId, familyId])
}

model UserChallengeTierUnlock {
  id         String        @id @default(cuid())
  userId     String
  tierId     String
  unlockedAt DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier       ChallengeTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@unique([userId, tierId])
}

model AvatarItem {
  id          String           @id @default(cuid())
  key         String           @unique
  title       String
  slot        String
  unlockLevel Int              @default(1)
  costXp      Int?
  inventory   UserAvatarItem[]
}

model UserAvatarItem {
  id           String     @id @default(cuid())
  userId       String
  avatarItemId String
  unlockedAt   DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarItem   AvatarItem @relation(fields: [avatarItemId], references: [id], onDelete: Cascade)

  @@unique([userId, avatarItemId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Challenge {
  id           String                @id @default(cuid())
  key          String                @unique
  title        String
  description  String
  metric       ChallengeMetric
  periodStart  DateTime
  periodEnd    DateTime
  target       Int?
  isActive     Boolean               @default(true)
  participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id          String    @id @default(cuid())
  challengeId String
  userId      String
  score       Int       @default(0)
  joinedAt    DateTime  @default(now())
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

model ActivityEvent {
  id        String       @id @default(cuid())
  userId    String
  type      ActivityType
  title     String
  body      String?
  payload   Json?
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions Reaction[]
}

model Reaction {
  id              String        @id @default(cuid())
  activityEventId String
  userId          String
  emoji           String
  createdAt       DateTime      @default(now())

  activityEvent   ActivityEvent @relation(fields: [activityEventId], references: [id], onDelete: Cascade)
  user            User          @relation("reactions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityEventId, userId, emoji])
  @@index([activityEventId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  payload   Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt(sort: Desc)])
}

model BodyMetricEntry {
  id           String   @id @default(cuid())
  userId       String
  weightKg     Float?
  measurements Json?
  note         String?
  recordedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt(sort: Desc)])
}

model WorkoutInvite {
  id               String   @id @default(cuid())
  fromUserId       String
  toUserId         String
  fromSessionId    String?
  programWorkoutId String?
  templateId       String?
  workoutTitle     String
  exercises        Json
  status           String   @default("PENDING")
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  fromUser         User     @relation("sentInvites", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser           User     @relation("receivedInvites", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, status])
}

enum SuppForm {
  TABLET
  CAPSULE
  POWDER
  LIQUID
  INJECTION
  OTHER
}

enum SuppSlot {
  MORNING
  MIDDAY
  EVENING
  BEDTIME
  PRE_WORKOUT
  INTRA_WORKOUT
  POST_WORKOUT
  CUSTOM
}

enum SuppFreq {
  DAILY
  WEEKLY
  EVERY_N_DAYS
  AS_NEEDED
}

enum IntakeStatus {
  TAKEN
  SKIPPED
  SNOOZED
  MISSED
}

enum CyclePhaseKind {
  ON
  OFF
  LOAD
  MAINTAIN
  PCT
  BRIDGE
  BLAST
  CRUISE
  TAPER_STEP
}

model Supplement {
  id                   String                  @id @default(cuid())
  userId               String
  name                 String
  brand                String?
  form                 SuppForm
  defaultUnit          String // mg|g|mcg|IU|ml|capsule|tablet|scoop|unit
  servingSize          Float?
  servingUnit          String?
  servingsPerContainer Float?
  tags                 String[]
  color                String?
  icon                 String?
  notes                String?
  archived             Boolean                 @default(false)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules            SupplementSchedule[]
  stackMembers         SupplementStackMember[]
  inventory            SupplementInventory?
  intakes              SupplementIntake[]

  @@index([userId])
}

model SupplementStack {
  id        String                  @id @default(cuid())
  userId    String
  name      String
  goal      String?
  color     String?
  paused    Boolean                 @default(false)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  members   SupplementStackMember[]
  schedules SupplementSchedule[]

  @@index([userId])
}

model SupplementStackMember {
  id           String          @id @default(cuid())
  stackId      String
  supplementId String
  sortOrder    Int             @default(0)
  stack        SupplementStack @relation(fields: [stackId], references: [id], onDelete: Cascade)
  supplement   Supplement      @relation(fields: [supplementId], references: [id], onDelete: Cascade)

  @@unique([stackId, supplementId])
  @@index([stackId])
}

model SupplementSchedule {
  id                 String                @id @default(cuid())
  supplementId       String
  stackId            String?
  cycleId            String?
  cyclePhaseId       String?
  doseAmount         Float
  doseUnit           String
  withFood           String? // with_food|empty_stomach|with_fat
  slot               SuppSlot
  clockTime          String? // "HH:mm" optional resolution of the slot
  freq               SuppFreq
  interval           Int                   @default(1)
  byWeekday          Int[] // 0-6 (Sun-Sat) for WEEKLY
  timesPerDay        Int                   @default(1)
  isPrn              Boolean               @default(false)
  prnMaxPerDay       Int?
  prnMinIntervalHrs  Int?
  startDate          DateTime
  endDate            DateTime?
  reminderEnabled    Boolean               @default(false)
  reminderWindowMins Int                   @default(60)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  supplement         Supplement            @relation(fields: [supplementId], references: [id], onDelete: Cascade)
  stack              SupplementStack?      @relation(fields: [stackId], references: [id], onDelete: SetNull)
  cycle              SupplementCycle?      @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  cyclePhase         SupplementCyclePhase? @relation(fields: [cyclePhaseId], references: [id], onDelete: SetNull)
  reminderLogs       SupplementReminderLog[]

  @@index([supplementId])
}

model SupplementCycle {
  id        String                 @id @default(cuid())
  userId    String
  name      String
  type      String
  startDate DateTime
  repeats   Boolean                @default(true)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  phases    SupplementCyclePhase[]
  schedules SupplementSchedule[]

  @@index([userId])
}

model SupplementCyclePhase {
  id             String               @id @default(cuid())
  cycleId        String
  order          Int
  kind           CyclePhaseKind
  durationDays   Int
  startDelayDays Int                  @default(0)
  label          String?
  cycle          SupplementCycle      @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  schedules      SupplementSchedule[]

  @@index([cycleId])
}

model SupplementIntake {
  id            String        @id @default(cuid())
  userId        String
  supplementId  String
  scheduleId    String?
  stackId       String?
  cyclePhaseId  String?
  scheduledFor  DateTime
  loggedAt      DateTime?
  status        IntakeStatus
  doseAmount    Float
  doseUnit      String
  source        String // manual|reminder|stack_bulk
  createdAt     DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplement    Supplement    @relation(fields: [supplementId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledFor])
}

model SupplementInventory {
  id                        String     @id @default(cuid())
  supplementId              String     @unique
  servingsRemaining         Float
  containerSize             Float?
  autoDecrement             Boolean    @default(true)
  lowStockThresholdServings Float      @default(7)
  reorderUrl                String?
  remindBeforeDays          Int        @default(5)
  updatedAt                 DateTime   @updatedAt
  supplement                Supplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)
}

// Web Push subscription (one row per browser/device endpoint).
model PushSubscription {
  id         String    @id @default(cuid())
  userId     String
  endpoint   String    @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Dedup marker so a supplement reminder isn't re-sent every cron tick. One row
// per (schedule, UTC day, kind) — see SupplementReminderLog usage in the cron.
model SupplementReminderLog {
  id          String   @id @default(cuid())
  scheduleId  String
  sentForDate DateTime // UTC midnight of the day the reminder is for
  kind        String // "due" | "followup"
  sentAt      DateTime @default(now())
  schedule    SupplementSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, sentForDate, kind])
  @@index([scheduleId])
}
