{
  "name": "liftiq",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:web": "npm --prefix web run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build:web": "npm --prefix web run build",
    "build:backend": "npm --prefix backend run build",
    "lint:web": "npm --prefix web run lint",
    "lint:backend": "npm --prefix backend run lint",
    "test:web": "npm --prefix web run test",
    "test:backend": "npm --prefix backend run test",
    "db:seed": "npm --prefix backend run prisma:seed",
    "db:migrate": "npm --prefix backend run prisma:migrate",
    "docker:prod:migrate": "docker compose --env-file .env.production -f docker-compose.prod.yml run --rm migrate",
    "docker:prod:seed": "docker compose --env-file .env.production -f docker-compose.prod.yml run --rm backend npm run prisma:seed",
    "docker:prod:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose --env-file .env.production -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose --env-file .env.production -f docker-compose.prod.yml logs -f",
    "docker:ghcr:deploy": "bash scripts/deploy-ghcr.sh",
    "docker:ghcr:seed": "bash scripts/seed-ghcr.sh",
    "docker:ghcr:logs": "bash scripts/logs-ghcr.sh"
  }
}
